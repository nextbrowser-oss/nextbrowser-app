{
  "name": "nextbrowser",
  "version": "0.1.13",
  "description": "NextBrowser desktop agent console for macOS and Windows",
  "author": "NextBrowser",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --port 1421\" \"wait-on tcp:1421 && cross-env VITE_DEV_SERVER_URL=http://localhost:1421 electron .\"",
    "build": "tsc && vite build",
    "test": "vitest run --exclude electron/ssh-config.test.cjs && node --test electron/ssh-config.test.cjs",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --publish never",
    "dist:publish": "npm run build && electron-builder --publish always",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.6.2",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.nextbrowser.desktop",
    "productName": "NextBrowser",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "nextbrowser-oss",
        "repo": "nextbrowser-app"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "artifactName": "NextBrowser-${version}-${arch}.${ext}",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "identity": "-",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
